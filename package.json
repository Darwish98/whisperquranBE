{
  "name": "quran-recitation-backend",
  "version": "1.0.0",
  "description": "Real-time Arabic speech recognition backend for Quran recitation",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node src/server.ts",
    "watch": "nodemon --exec ts-node src/server.ts"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "microsoft-cognitiveservices-speech-sdk": "^1.38.0",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.10",
    "nodemon": "^3.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18"
  }
}
