# =============================================
# Quran Recitation Backend – Environment Variables
# Copy this to .env and fill in your values
# =============================================

# Azure Cognitive Services – Speech
# Get from: Azure Portal → Your Speech resource → Keys and Endpoint
AZURE_SPEECH_KEY=YOUR_AZURE_SPEECH_KEY_HERE
AZURE_SPEECH_REGION=eastus

# Server
PORT=8000

# CORS – comma-separated allowed frontend origins
# Use * for development, restrict in production
ALLOWED_ORIGINS=http://localhost:5173,https://YOUR-LOVABLE-APP.lovable.app



SUPABASE_JWT_SECRET=
